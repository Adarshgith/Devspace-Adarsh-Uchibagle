{
  "name": "competition",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "validate:env": "node scripts/validate-env.js",
    "validate:schemas": "node scripts/validate-schemas.js",
    "security:audit": "node scripts/security-audit.js",
    "seed:import": "node scripts/seed-data.js import",
    "seed:remove": "node scripts/seed-data.js remove",
    "seed:check": "node scripts/check-conflicts.js",
    "seed:help": "node scripts/seed-data.js",
    "fix:schema": "node scripts/fix-schema-validation.js",
    "validate:fixes": "node scripts/validate-schema-fixes.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "quality:check": "npm run type-check && npm run lint && npm run format:check && npm run test && npm run validate:schemas && npm run security:audit"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/cli": "^3.21.0",
    "@sanity/client": "^6.7.0",
    "@sanity/vision": "^3.21.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.11.0",
    "react-is": "^18.2.0",
    "sanity": "^3.21.0",
    "styled-components": "^6.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^5.0.1",
    "@sanity/table": "^1.1.3",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.0.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.5.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
